# Налаштування сервера
PORT=4000

# Підключення до PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/studorg_docflow

# Секрет для підпису JWT-токенів (замініть на власний)
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=7d

# Дозволене джерело для CORS (фронтенд)
CLIENT_ORIGIN=http://localhost:5173

# Email (SMTP). Якщо не заповнено — листи лише логуються в консоль (режим розробки)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@studorg-docflow.local
